{
  "name": "opengameinstaller-gui",
  "version": "4.0.0",
  "description": "The front-facing GUI for OpenGameInstaller and the addon-server.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "./out/main/index.js",
  "author": "Nat3z",
  "build": {
    "icon": "public/favicon.ico",
    "productName": "OpenGameInstaller",
    "npmRebuild": false,
    "extends": null,
    "files": [
      "public/**/*",
      "out/**/*",
      "node_modules/**/*"
    ],
    "win": {},
    "linux": {
      "icon": "public/favicon-256x256.png",
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "artifactName": "${productName}-linux-pt.${ext}"
    },
    "mac": {
      "icon": "public/favicon-512x512.png",
      "artifactName": "${productName}-mac.${ext}"
    }
  },
  "scripts": {
    "build": "electron-vite build",
    "build:all": "bun run --cwd .. --filter './packages/*' build",
    "dev": "bun run build:all && ELECTRON_EXEC_PATH=\"$(bun -e \"console.log(require('electron'))\" )\" electron-vite dev",
    "preview": "electron-vite preview",
    "dev:server": "nodemon --watch server --ext ts,json --exec \"tsc --p tsconfig.addonserver.json && bun run --bun build-addons/dev-server.js\"",
    "preelectron-pack": "bun run build:all && bun run build && electron-rebuild",
    "preelectron-pack:linux": "bun run build:all && bun run build && electron-rebuild",
    "electron-pack": "electron-builder",
    "format": "prettier --write \"src/**/*.{ts,svelte,json}\"",
    "typecheck": "tsc -p src/electron/tsconfig.json --noEmit && svelte-check --tsconfig src/frontend/tsconfig.json",
    "electron-pack:linux": "electron-builder -l"
  },
  "dependencies": {
    "@ctrl/qbittorrent": "^9.11.0",
    "@ogi-sdk/addon-server": "workspace:*",
    "@ogi-sdk/client-kit": "workspace:*",
    "@ogi-sdk/connect": "workspace:*",
    "@ogi-sdk/executor": "workspace:*",
    "@types/express": "^4.17.25",
    "all-debrid-js": "workspace:*",
    "axios": "^1.13.4",
    "d3": "^7.9.0",
    "express": "^4.22.1",
    "node-datachannel": "^0.32.0",
    "ogi-addon": "workspace:*",
    "parse-torrent": "^11.0.19",
    "real-debrid-js": "workspace:*",
    "sanitize-html": "^2.17.0",
    "semver": "^7.7.3",
    "shell-quote": "^1.8.3",
    "utp-native": "^2.5.3",
    "webtorrent": "^2.8.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/svelte": "^5.0.6",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.15.0",
    "@types/sanitize-html": "^2.16.0",
    "@types/semver": "^7.7.1",
    "@types/shell-quote": "^1.7.5",
    "@types/webtorrent": "^0.110.1",
    "concurrently": "^7.6.0",
    "debug": "^4.4.3",
    "@electron/rebuild": "^3.7.2",
    "electron": "^40.1.0",
    "electron-builder": "^23.6.0",
    "electron-vite": "^5.0.0",
    "nodemon": "^3.1.11",
    "svelte": "^5.49.1",
    "svelte-check": "^4.3.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "vite": "^6.4.1",
    "wait-on": "^6.0.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3",
    "undici": "^7.16.0",
    "undici-types": "^7.16.0"
  },
  "trustedDependencies": [
    "electron"
  ]
}
