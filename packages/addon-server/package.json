{
  "name": "@ogi-sdk/addon-server",
  "type": "module",
  "version": "1.0.1",
  "module": "./build/index.mjs",
  "main": "./build/index.cjs",
  "exports": {
    ".": {
      "import": {
        "default": "./build/index.mjs",
        "types": "./build/index.d.mts"
      },
      "require": {
        "default": "./build/index.cjs",
        "types": "./build/index.d.cts"
      }
    }
  },
  "scripts": {
    "generate:event-proxy": "bun scripts/generate-event-proxy.ts",
    "prebuild": "bun run generate:event-proxy",
    "build": "bun run prebuild && tsdown --config tsdown.config.js",
    "typecheck": "tsc --noEmit",
    "release": "bun run build && npm publish --access public",
    "release-beta": "bun run build && npm publish --access public --tag future"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/websocket": "^1.0.10",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ogi-sdk/connect": "^1.0.1",
    "elysia": "^1.4.28",
    "ogi-addon": "^4.0.1",
    "websocket": "^1.0.35",
    "ws": "^8.20.0"
  },
  "description": "HTTP/WebSocket addon server for OpenGameInstaller addon integrations.",
  "license": "MIT",
  "author": {
    "name": "Nat3z",
    "email": "me@nat3z.com",
    "url": "https://nat3z.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nat3z/OpenGameInstaller",
    "directory": "packages/addon-server"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ]
}
