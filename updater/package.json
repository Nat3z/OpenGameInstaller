{
  "name": "ogi-updater",
  "version": "2.0.0",
  "type": "module",
  "description": "OpenGameInstaller Launcher and Updater",
  "main": "dist/main.js",
  "author": "Nat3z",
  "build": {
    "icon": "public/favicon.ico",
    "productName": "OpenGameInstaller",
    "files": [
      "public/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup.${ext}"
    },
    "linux": {
      "icon": "public/favicon-256x256.png",
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "mac": {}
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc -p tsconfig.json",
    "dev": "bun run build && electron .",
    "preelectron-pack": "bun run build",
    "electron-pack": "electron-builder"
  },
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/yauzl": "^2.10.3",
    "electron": "^40.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "electron"
  ]
}
